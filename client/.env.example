# =============================================================================
# MiAyudaTIC — Frontend (.env)
# Copia a .env para desarrollo local. NO commitear secretos.
# En Vercel: Dashboard → Settings → Environment Variables.
# =============================================================================

# --- Desarrollo local ---
# URL del backend SIN /api (axios añade /api automáticamente)
VITE_BACKEND_URL=http://localhost:8000

# --- Producción (Vercel) — usa UNA de estas dos formas ---
# Opción A (recomendada): host del backend sin /api
# VITE_BACKEND_URL=https://miayudatics-api.onrender.com

# Opción B (compat. docs): URL completa con /api
# VITE_API_URL=https://miayudatics-api.onrender.com/api
