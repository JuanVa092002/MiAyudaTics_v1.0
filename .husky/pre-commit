#!/usr/bin/env sh

echo "⏳ Running pre-commit checks (TypeScript & ESLint)..."

echo "1/4: Type-checking Server..."
cd server && pnpm exec tsc --noEmit || { echo "❌ Server TS check failed"; exit 1; }
cd ..

echo "2/4: Type-checking Client..."
cd client && pnpm exec tsc --noEmit || { echo "❌ Client TS check failed"; exit 1; }
cd ..

echo "3/4: Linting Server..."
cd server && pnpm exec eslint --fix . || { echo "❌ Server ESLint failed"; exit 1; }
cd ..

echo "4/4: Linting Client..."
cd client && pnpm exec eslint --fix . || { echo "❌ Client ESLint failed"; exit 1; }
cd ..

echo "✅ All pre-commit checks passed!"
