{
  "name": "miayudatics-root",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "smoke:prod": "bash scripts/smoke-prod.sh",
    "e2e:ticket": "bash scripts/e2e-ticket-lifecycle.sh",
    "smoke:mobile-api": "bash scripts/smoke-mobile-api.sh",
    "smoke:mobile-client": "pnpm -C server exec ts-node --transpile-only src/scripts/mobile-smoke-client.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.52.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7"
  }
}
