# =============================================================================
# MiAyudaTIC — Backend (.env.example)
# Copia: cp .env.example .env
# Render: pegar las mismas claves en Dashboard → Environment.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Entorno
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8000

# -----------------------------------------------------------------------------
# 2. Base de datos (MongoDB Atlas)
# -----------------------------------------------------------------------------
DB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/miayudatics?appName=Cluster0
# MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4

# -----------------------------------------------------------------------------
# 3. URLs y CORS
# -----------------------------------------------------------------------------
PUBLIC_URL=http://localhost:8000
RENDER_URL=http://localhost:8000
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# LEGACY_RENDER_FRONTEND_URL=

# -----------------------------------------------------------------------------
# 4. Autenticación
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production

# -----------------------------------------------------------------------------
# 5. Email (Brevo)
# -----------------------------------------------------------------------------
BREVO_API_KEY=xkeysib-your-api-key
BREVO_USER=tu-email@ejemplo.com
BREVO_PASSWORD=xsmtpsib-your-smtp-key
EMAIL_FROM=MiAyudaTics <tu-email@ejemplo.com>
EMAIL=tu-email@ejemplo.com
EMAIL_USER=tu-email@ejemplo.com

# -----------------------------------------------------------------------------
# 6. Cloudinary (recomendado producción / Render)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=miayudatics
# CLOUDINARY_DEFAULT_AVATAR_URL=

# -----------------------------------------------------------------------------
# 7. Storage local (fallback si Cloudinary vacío)
# -----------------------------------------------------------------------------
STORAGE_PATH=storage

# -----------------------------------------------------------------------------
# 8. Mobile platform (Fase 4)
# -----------------------------------------------------------------------------
MEDIA_MAX_BYTES=10485760
# SOCKET_CORS_ORIGINS=   # opcional; fallback CORS_ORIGINS
# REDIS_URL=             # opcional; multi-instancia Socket.IO
# REQUIRE_SOLICITUD_FOTO=false

# =============================================================================
# PRODUCCIÓN (Render)
# =============================================================================
# NODE_ENV=production
# PUBLIC_URL=https://miayudatics-api.onrender.com
# RENDER_URL=https://miayudatics-api.onrender.com
# CLIENT_URL=https://tu-app.vercel.app
# CORS_ORIGINS=https://tu-app.vercel.app
# JWT_SECRET=<openssl rand -base64 48>
