# =============================================================================
# MiAyudaTIC — Backend — tests de integración
# Copia: cp .env.test.example .env.test
# Usa una DB separada (NO producción).
# =============================================================================

NODE_ENV=test
PORT=8000
JWT_SECRET=test_secret_integration

DB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/miayudatics_simulation?appName=Cluster0

CLIENT_URL=http://localhost:5173
PUBLIC_URL=http://localhost:8000
RENDER_URL=http://localhost:8000

# Cloudinary opcional en tests de integración (dejar vacío = disco local)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
STORAGE_PATH=storage
