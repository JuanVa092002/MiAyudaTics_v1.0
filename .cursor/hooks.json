{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/post-edit-lint.sh"
      },
      {
        "command": ".cursor/hooks/contract-sync-check.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/dangerous-command-guard.sh"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/handoff-reminder.sh"
      }
    ]
  }
}
