# =============================================================================
# MiAyudaTIC — Backend (.env)
# Copia a .env y completa los valores. NO commitear .env con secretos reales.
# En Render: pega estas mismas variables en Dashboard → Environment.
# =============================================================================

# --- Entorno ---
NODE_ENV=development
# Producción (Render): NODE_ENV=production

PORT=8000

# --- Base de datos (MongoDB Atlas) ---
DB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/miayudatics?appName=Cluster0

# --- URLs públicas ---
# Local: URL del API (sin /api al final)
PUBLIC_URL=http://localhost:8000
# URL del frontend (cookies, links de reset password, CORS)
CLIENT_URL=http://localhost:5173
# Orígenes CORS extra (coma-separados). CLIENT_URL se añade automáticamente.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Producción: CORS_ORIGINS=https://tu-app.vercel.app

# URL pública del backend en la nube (archivos /storage). En local puede igualar PUBLIC_URL.
RENDER_URL=http://localhost:8000
# Producción: RENDER_URL=https://tu-backend.onrender.com

# --- Auth ---
# Genera uno fuerte en producción: openssl rand -base64 48
JWT_SECRET=change_me_in_production

# --- Email (Brevo) — preferido: API REST ---
BREVO_API_KEY=xkeysib-your-api-key
# Respaldo SMTP (opcional si no usas BREVO_API_KEY)
BREVO_USER=tu-email@ejemplo.com
BREVO_PASSWORD=xsmtpsib-your-smtp-key

# Remitente (debe estar verificado en Brevo → Senders)
EMAIL_FROM=MiAyudaTics <tu-email@ejemplo.com>
EMAIL=tu-email@ejemplo.com
EMAIL_USER=tu-email@ejemplo.com

# =============================================================================
# PRODUCCIÓN (Render) — referencia rápida
# =============================================================================
# NODE_ENV=production
# PORT=8000
# DB_URI=mongodb+srv://...
# PUBLIC_URL=https://miayudatics-api.onrender.com
# CLIENT_URL=https://miayudatics.vercel.app
# CORS_ORIGINS=https://miayudatics.vercel.app
# RENDER_URL=https://miayudatics-api.onrender.com
# JWT_SECRET=<secreto-largo-aleatorio>
# BREVO_API_KEY=xkeysib-...
